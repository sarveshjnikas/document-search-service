{
  "name": "document-search-service",
  "version": "1.0.0",
  "description": "Distributed document search service prototype",
  "main": "dist/boot.js",
  "scripts": {
    "dev": "tsx watch src/boot.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/boot.js",
    "db:setup": "tsx src/scripts/setup-db.ts",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "license": "ISC",
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "mysql2": "^3.14.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "typedi": "^0.10.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.1",
    "jest": "^30.0.4",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
