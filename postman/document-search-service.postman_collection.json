            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Senior Backend Engineer\",\n  \"employmentType\": \"full_time\",\n  \"isRemote\": true,\n  \"details\": \"Build and scale a distributed job search platform with MySQL-backed storage and tenant isolation.\",\n  \"minSalary\": 120000,\n  \"maxSalary\": 180000,\n  \"location\": \"Bengaluru\",\n  \"companyName\": \"Acme\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/documents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Job Postings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search?q=distributed&tenant={{tenantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "distributed"
                },
                {
                  "key": "tenant",
                  "value": "{{tenantId}}"
                }
              ]
            }
          },
          "response": []
        },
        {
